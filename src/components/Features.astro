---
const features = [
  {
    title: "Экологичные материалы",
    description: "Гофрокартон из переработанной бумаги. Безопасен для детей и природы.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none" aria-hidden="true">
      <circle cx="32" cy="32" r="28" fill="#E8F5E9"/>
      <path d="M32 16c0 0-12 8-12 18a12 12 0 0 0 24 0c0-10-12-18-12-18z" fill="#4CAF50"/>
      <path d="M32 22v18M26 30c3-2 6-2 9 0" stroke="#2E7D32" stroke-width="2" stroke-linecap="round"/>
    </svg>`,
  },
  {
    title: "Без клея и ножниц",
    description: "Система пазов: всё собирается руками. Идеально для детской моторики.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none" aria-hidden="true">
      <circle cx="32" cy="32" r="28" fill="#FFF3E0"/>
      <rect x="18" y="26" width="28" height="18" rx="3" fill="#FF9800" stroke="#E65100" stroke-width="1.5"/>
      <path d="M24 26v-4a8 8 0 0 1 16 0v4" stroke="#E65100" stroke-width="2" stroke-linecap="round"/>
      <rect x="28" y="33" width="8" height="5" rx="2" fill="#fff" opacity="0.7"/>
    </svg>`,
  },
  {
    title: "Раскрась как хочешь",
    description: "Белый картон — чистый холст. Фломастеры, краски, наклейки — всё подойдёт.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none" aria-hidden="true">
      <circle cx="32" cy="32" r="28" fill="#F3E5F5"/>
      <rect x="20" y="18" width="24" height="28" rx="3" fill="#fff" stroke="#CE93D8" stroke-width="1.5"/>
      <path d="M25 28h14M25 34h10M25 40h12" stroke="#AB47BC" stroke-width="2" stroke-linecap="round"/>
      <circle cx="42" cy="20" r="5" fill="#E85D2A"/>
      <path d="M42 17v6M39 20h6" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/>
    </svg>`,
  },
  {
    title: "Быстрая доставка",
    description: "1–2 дня по Москве, 3–7 дней по России. Надёжная упаковка.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none" aria-hidden="true">
      <circle cx="32" cy="32" r="28" fill="#E3F2FD"/>
      <rect x="12" y="26" width="24" height="16" rx="2" fill="#2196F3"/>
      <path d="M36 30h6l6 6v6H36V30z" fill="#1565C0"/>
      <circle cx="20" cy="44" r="4" fill="#fff" stroke="#1565C0" stroke-width="2"/>
      <circle cx="44" cy="44" r="4" fill="#fff" stroke="#1565C0" stroke-width="2"/>
      <path d="M12 32H8" stroke="#64B5F6" stroke-width="2" stroke-linecap="round"/>
      <path d="M12 36H6" stroke="#64B5F6" stroke-width="2" stroke-linecap="round"/>
    </svg>`,
  },
];
---

<section id="features" class="section features-section">
  <div class="container">
    <h2 class="section-title animate-on-scroll">Почему наши домики?</h2>
    <div class="features-grid">
      {features.map((feature, index) => (
        <article
          class="feature-card animate-on-scroll"
          style={`transition-delay: ${index * 0.1}s`}
        >
          <div class="feature-icon" set:html={feature.icon} />
          <h3 class="feature-title">{feature.title}</h3>
          <p class="feature-description">{feature.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .features-section {
    background: var(--color-bg-alt);
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .feature-card {
    background: var(--color-bg);
    border-radius: var(--radius-lg);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    box-shadow: var(--shadow-sm);
    border: 1.5px solid var(--color-border);
    transition: transform var(--transition), box-shadow var(--transition), border-color var(--transition);
    cursor: default;
  }

  .feature-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-primary-light);
  }

  .feature-icon {
    width: 64px;
    height: 64px;
    flex-shrink: 0;
  }

  .feature-icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  .feature-title {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--color-text);
    line-height: 1.3;
  }

  .feature-description {
    font-size: 0.95rem;
    color: var(--color-text-light);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 640px) {
    .features-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .feature-card {
      padding: 24px 20px;
    }
  }
</style>
